{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "es5",
  "jsxSingleQuote": false,
  "singleQuote": true,
  "useTabs": false,
  "tabWidth": 2,
  "semi": false,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": ["**/__snapshots__/**/*.ts", "**/__snapshots__/**/*.js"]
}
